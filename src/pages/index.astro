---
// Coming Soon splash for AeternusForge.
// This temporarily replaces the homepage. To GO LIVE later, revert the commit
// that added this (GitHub > Commits > this commit > Revert) — that restores your
// real homepage. This page is fully self-contained on purpose (no theme imports),
// so it cannot break your build.
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AeternusForge — Coming Soon</title>
    <meta
      name="description"
      content="AeternusForge is being forged — project builds, printable files, and honest gear notes, coming soon."
    />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #0b0f17;
        --fg: #e6edf3;
        --accent: #ff7a3c;
        --muted: #8a94a6;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; }
      body {
        background: radial-gradient(1200px 600px at 50% -10%, #16202e 0%, var(--bg) 60%);
        color: var(--fg);
        font-family: "Space Grotesk", system-ui, sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        text-align: center;
        padding: 24px;
        -webkit-font-smoothing: antialiased;
      }
      .scanline {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--accent), transparent);
        box-shadow: 0 0 14px 1px var(--accent);
      }
      .eyebrow {
        font-size: 0.72rem;
        letter-spacing: 0.42em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 22px;
      }
      h1 {
        font-size: clamp(2.4rem, 8vw, 4.5rem);
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        line-height: 1;
      }
      h1 .spark {
        color: var(--accent);
        text-shadow: 0 0 26px rgba(255, 122, 60, 0.55);
      }
      .rule {
        width: 60px;
        height: 2px;
        background: var(--accent);
        margin: 26px auto;
        opacity: 0.8;
        box-shadow: 0 0 12px var(--accent);
      }
      .status { font-size: 1.05rem; font-weight: 500; letter-spacing: 0.02em; }
      .tag {
        margin-top: 14px;
        color: var(--muted);
        max-width: 46ch;
        line-height: 1.6;
        font-size: 0.98rem;
      }
      .contact { margin-top: 34px; font-size: 0.9rem; color: var(--muted); }
      .contact a { color: var(--accent); text-decoration: none; }
      .contact a:hover { text-shadow: 0 0 12px rgba(255, 122, 60, 0.5); }
      footer {
        position: fixed;
        bottom: 18px;
        font-size: 0.72rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #4b5568;
      }
      @media (prefers-reduced-motion: no-preference) {
        h1 .spark { animation: pulse 3.2s ease-in-out infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.72; } }
      }
    </style>
  </head>
  <body>
    <div class="scanline"></div>
    <h1>Aeternus<span class="spark">Forge</span></h1>
    <div class="rule"></div>
    <p class="status">The workshop is under construction.</p>
    <p class="contact">
      Questions? <a href="mailto:aeternusforge@protonmail.com">aeternusforge@protonmail.com</a>
    </p>
    <footer>AeternusForge</footer>
  </body>
</html>
