---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconHash from "@/assets/icons/IconHash.svg";
import config from "@/config";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
---

<li>
   
    href={getRelativeLocaleUrl(locale, `tags/${tag}/`)}
    transition:name={tag}
    class:list={[
      "inline-flex items-center gap-0.5",
      // Light mode: solid filled chip
      "rounded-md border border-accent bg-accent px-2.5 py-0.5 text-accent-foreground hover:opacity-85",
      // Dark mode: revert to the minimal dashed-underline look
      "dark:rounded-none dark:border-0 dark:border-b-2 dark:border-dashed dark:border-foreground dark:bg-transparent dark:px-0 dark:py-0 dark:text-inherit",
      "dark:hover:-mt-0.5 dark:hover:border-accent dark:hover:text-accent dark:hover:opacity-100",
      "focus-visible:border-none dark:focus-visible:text-accent",
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-80",
        { "size-5": size === "lg" },
        { "size-4": size === "sm" },
      ]}
    />
    {tagName}
  </a>
</li>
